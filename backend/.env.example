# ============================================================
# Mini-Han Backend — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before starting the server.
# NEVER commit .env to git.

# --- Aurora PostgreSQL (from AWS Secrets Manager) ---
DB_HOST=ragstack-ragdatabase4961bfdb-ot23vvg32pbj.cx84scemy9xh.ap-northeast-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ragdb
DB_USER=ragadmin
DB_PASSWORD=         # run: python3 scripts/get_db_password.py

# --- OpenAI (for embeddings only — text-embedding-3-large) ---
# The Aurora DB was indexed with this model; it cannot be changed without re-indexing.
OPENAI_API_KEY=sk-...

# --- Chat generation ---
# Provider: "groq" (default, free tier) | "openai" | "ollama"
CHAT_PROVIDER=groq
GROQ_API_KEY=gsk_...          # free key from console.groq.com
CHAT_MODEL=llama-3.3-70b-versatile

# If using OpenAI for chat instead of Groq:
# CHAT_PROVIDER=openai
# CHAT_MODEL=gpt-4o-mini
# (OPENAI_API_KEY above will be used)

# If using local Ollama instead:
# CHAT_PROVIDER=ollama
# CHAT_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434

# --- Freemium / Subscription ---
# Comma-separated list of valid subscription tokens you give to paying users.
# Generate tokens however you like (e.g. UUIDs, Stripe webhooks, manual).
# Example: VALID_TOKENS=tok_abc123,tok_def456,tok_xyz789
VALID_TOKENS=

# Optional: override the free prompt limit (default: 10)
# FREE_PROMPT_LIMIT=10
